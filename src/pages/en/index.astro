---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import HeroSection from '../../components/HeroSection.astro';
import WhyFlorida from '../../components/WhyFlorida.astro';
import InvestmentProducts from '../../components/InvestmentProducts.astro';
import InvestmentProcess from '../../components/InvestmentProcess.astro';
import ROICalculator from '../../components/ROICalculator.astro';
import HouseModels from '../../components/HouseModels.astro';
import WhyChooseUs from '../../components/WhyChooseUs.astro';
import Testimonials from '../../components/Testimonials.astro';
import ContactSection from '../../components/ContactSection.astro';
import Footer from '../../components/Footer.astro';
import { translations } from '../../i18n/translations';

const t = translations.en;
---

<Layout title={t.meta.title} description={t.meta.description}>
  <Navbar t={t} lang="en" />
  <main>
    <HeroSection t={t} />
    <WhyFlorida t={t} />
    <InvestmentProducts t={t} />
    <InvestmentProcess t={t} />
    <ROICalculator t={t} />
    <HouseModels t={t} />
    <WhyChooseUs t={t} />
    <Testimonials t={t} />
    <ContactSection t={t} />
  </main>
  <Footer t={t} />
</Layout>
