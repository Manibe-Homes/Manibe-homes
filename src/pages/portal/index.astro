<script>
  const VALID_EMAIL = 'juan@manibehomes.com';
  const VALID_PASS  = 'Manibe2025';

  const loginScreen = document.getElementById('login-screen')!;
  const dashboard   = document.getElementById('dashboard')!;
  const loginForm   = document.getElementById('login-form')!;
  const loginError  = document.getElementById('login-error')!;
  const logoutBtn   = document.getElementById('logout-btn')!;
  const toast       = document.getElementById('toast')!;

  // ── Toast helper ──
  let toastTimer: ReturnType<typeof setTimeout>;
  function showToast(msg: string) {
    toast.textContent = msg;
    toast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove('show'), 2000);
  }

  // ── Session check ──
  if (sessionStorage.getItem('portal-auth') === '1') {
    loginScreen.style.display = 'none';
    dashboard.style.display = 'block';
  }

  // ── Login ──
  loginForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = (document.getElementById('login-email') as HTMLInputElement).value.trim();
    const pass  = (document.getElementById('login-pass') as HTMLInputElement).value;

    if (email === VALID_EMAIL && pass === VALID_PASS) {
      sessionStorage.setItem('portal-auth', '1');
      loginScreen.style.display = 'none';
      dashboard.style.display = 'block';
      loginError.style.display = 'none';
    } else {
      loginError.style.display = 'block';
    }
  });

  // ── Logout ──
  logoutBtn.addEventListener('click', () => {
    sessionStorage.removeItem('portal-auth');
    loginScreen.style.display = 'flex';
    dashboard.style.display = 'none';
    (document.getElementById('login-email') as HTMLInputElement).value = '';
    (document.getElementById('login-pass') as HTMLInputElement).value = '';
  });

  // ── Accordion with smooth height ──
  document.querySelectorAll('[data-stage-toggle]').forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const stage = toggle.closest('[data-stage]')!;
      const body = stage.querySelector('.stage-body') as HTMLElement;

      if (stage.classList.contains('open')) {
        body.style.maxHeight = body.scrollHeight + 'px';
        requestAnimationFrame(() => { body.style.maxHeight = '0'; });
        stage.classList.remove('open');
      } else {
        stage.classList.add('open');
        body.style.maxHeight = body.scrollHeight + 'px';
        body.addEventListener('transitionend', () => {
          if (stage.classList.contains('open')) body.style.maxHeight = '800px';
        }, { once: true });
      }
    });
  });

  // Init open stage height
  document.querySelectorAll('.stage.open .stage-body').forEach((b) => {
    (b as HTMLElement).style.maxHeight = '800px';
  });

  // ── Copy buttons with toast ──
  document.querySelectorAll('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const text = (btn as HTMLElement).dataset.copy!;
      navigator.clipboard.writeText(text).then(() => showToast('Copiado \u2713'));
    });
  });

  // ── Password toggle ──
  const camPass   = document.getElementById('cam-pass')!;
  const toggleBtn = document.getElementById('toggle-pass')!;
  let passVisible = false;

  toggleBtn.addEventListener('click', () => {
    passVisible = !passVisible;
    camPass.textContent = passVisible ? camPass.dataset.real! : '\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022';
    toggleBtn.title = passVisible ? 'Ocultar' : 'Mostrar';
    const svg = toggleBtn.querySelector('svg')!;
    if (passVisible) {
      svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.878 9.878L6.59 6.59m7.532 7.532l3.29 3.29M3 3l18 18" />';
    } else {
      svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />';
    }
  });

  // ── Nav tabs smooth scroll ──
  document.querySelectorAll('.portal-nav a[data-nav]').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const target = (link as HTMLAnchorElement).getAttribute('href')!;
      const el = document.querySelector(target);
      if (el) {
        el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
      document.querySelectorAll('.portal-nav a').forEach(a => a.classList.remove('active'));
      link.classList.add('active');
    });
  });
</script>

</body>
</html>
