---
// Phone and message are hardcoded — not translatable
const phone = '12392996978';
const msgES  = encodeURIComponent('Hola Manibe, me interesa conocer más sobre sus productos de inversión.');
const msgEN  = encodeURIComponent('Hello Manibe, I am interested in learning more about your investment products.');
---

<a
  id="wa-float"
  href={`https://wa.me/${phone}?text=${msgES}`}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar por WhatsApp"
  class="fixed bottom-6 right-6 z-50 group"
>
  <!-- Pulse ring -->
  <span class="absolute inset-0 rounded-full bg-[#25D366] opacity-30 animate-ping"></span>

  <!-- Button -->
  <span class="relative flex items-center justify-center w-14 h-14 rounded-full
               bg-[#25D366] hover:bg-[#1da851] shadow-lg hover:shadow-xl
               transition-all duration-300 hover:scale-110">
    <svg viewBox="0 0 24 24" class="h-7 w-7 fill-white" xmlns="http://www.w3.org/2000/svg">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.118 1.532 5.849L.057 23.625a.75.75 0 00.918.918l5.776-1.475A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.738 9.738 0 01-5.003-1.38l-.358-.213-3.712.949.964-3.625-.234-.374A9.738 9.738 0 012.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/>
    </svg>
  </span>

  <!-- Tooltip -->
  <span class="absolute right-16 top-1/2 -translate-y-1/2 bg-earth-900 text-white text-xs
               font-semibold px-3 py-1.5 rounded-lg whitespace-nowrap shadow-lg
               opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none">
    WhatsApp
  </span>
</a>

<script define:vars={{ msgES, msgEN, phone }}>
  // Swap message based on page language
  const isEN = window.location.pathname.startsWith('/en');
  const waLink = document.getElementById('wa-float');
  if (waLink && isEN) {
    waLink.href = `https://wa.me/${phone}?text=${msgEN}`;
  }
</script>
