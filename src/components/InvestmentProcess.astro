---
import type { Translations } from '../i18n/translations';
interface Props { t: Translations; }
const { t } = Astro.props;
const p = t.process;

const icons = [
  // 01 Contacto — chat bubble
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
    d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />`,
  // 02 Selección — clipboard check
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />`,
  // 03 Firma — document
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
    d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />`,
  // 04 Construcción — home
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
    d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />`,
  // 05 Retorno — trending up
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
    d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />`,
];
---

<section id="proceso" class="py-24 bg-earth-50 relative overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-earth-200 to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-earth-200 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <span class="inline-block text-earth-500 text-sm font-semibold tracking-widest uppercase mb-4">
        {p.tag}
      </span>
      <h2 class="section-title text-earth-900 mb-4">
        {p.title1} <span class="text-earth-600">{p.title2}</span>
      </h2>
      <p class="text-earth-500 text-lg font-body max-w-xl mx-auto leading-relaxed">
        {p.intro}
      </p>
    </div>

    <!-- Timeline — desktop horizontal, mobile vertical -->
    <div class="relative">

      <!-- Connecting line desktop -->
      <div class="hidden lg:block absolute top-10 left-0 right-0 h-px bg-earth-200 z-0"
           style="left: calc(10%); right: calc(10%);"></div>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-4 relative z-10">
        {p.steps.map((step, i) => (
          <div class={`reveal delay-${i * 100} flex lg:flex-col items-start lg:items-center gap-5 lg:gap-0 lg:text-center group`}>

            <!-- Step icon + number -->
            <div class="flex-shrink-0 flex flex-col items-center lg:mb-6">
              <!-- Connector line for mobile (left side) -->
              {i < p.steps.length - 1 && (
                <div class="lg:hidden absolute left-[22px] mt-[56px] w-px bg-earth-200"
                     style="height: calc(100% - 56px);"></div>
              )}

              <!-- Circle -->
              <div class={`relative w-11 h-11 rounded-full flex items-center justify-center
                           border-2 transition-all duration-300
                           ${i === 4
                             ? 'bg-gold-400 border-gold-400 shadow-lg shadow-gold-400/30'
                             : 'bg-white border-earth-200 group-hover:border-gold-400 group-hover:bg-gold-400/5'}`}>
                <svg xmlns="http://www.w3.org/2000/svg"
                     class={`h-5 w-5 transition-colors duration-300
                             ${i === 4 ? 'text-earth-900' : 'text-earth-400 group-hover:text-gold-500'}`}
                     fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <Fragment set:html={icons[i]} />
                </svg>
              </div>

              <!-- Step number -->
              <span class="mt-2 text-xs font-bold text-earth-400 tracking-widest">{step.number}</span>
            </div>

            <!-- Content -->
            <div class="lg:mt-0 pb-8 lg:pb-0 lg:px-2">
              <h3 class={`font-heading font-bold text-base mb-2 transition-colors duration-300
                          ${i === 4 ? 'text-gold-500' : 'text-earth-900 group-hover:text-gold-500'}`}>
                {step.title}
              </h3>
              <p class="text-earth-500 text-sm font-body leading-relaxed mb-3">
                {step.description}
              </p>
              <span class={`inline-flex items-center gap-1.5 text-xs font-semibold px-2.5 py-1 rounded-full
                            ${i === 4
                              ? 'bg-gold-400/15 text-gold-600'
                              : 'bg-earth-100 text-earth-500'}`}>
                <span class={`w-1.5 h-1.5 rounded-full flex-shrink-0
                              ${i === 4 ? 'bg-gold-400' : 'bg-earth-300'}`}></span>
                {step.detail}
              </span>
            </div>

          </div>
        ))}
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-14 reveal">
      <a href="#contacto"
        class="inline-flex items-center gap-2 bg-earth-900 hover:bg-earth-800
               text-white font-semibold text-sm px-8 py-4 rounded-full
               transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
        {t.nav.contact}
      </a>
    </div>

  </div>
</section>
