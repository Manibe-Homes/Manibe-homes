  [
    { label: isEN ? 'Covered area'  : 'Área bajo techo', value: '2,372 ft² / 220 m²' },
    { label: isEN ? 'A/C area'      : 'Área bajo aire',  value: '1,666 ft² / 155 m²' },
    { label: isEN ? 'Style'         : 'Estilo',           value: isEN ? 'Modern contemporary' : 'Moderno contemporáneo' },
    { label: isEN ? 'Garage'        : 'Garaje',           value: isEN ? 'Double' : 'Doble' },
  ],
  // Modelo Albany
  [
    { label: isEN ? 'Covered area'  : 'Área bajo techo', value: '2,381 ft² / 221 m²' },
    { label: isEN ? 'A/C area'      : 'Área bajo aire',  value: '1,731 ft² / 161 m²' },
    { label: isEN ? 'Style'         : 'Estilo',           value: isEN ? 'Modern contemporary' : 'Moderno contemporáneo' },
    { label: isEN ? 'Garage'        : 'Garaje',           value: isEN ? 'Triple' : 'Triple' },
