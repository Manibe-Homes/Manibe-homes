  // Modelo Canac
  [
    { label: isEN ? 'Covered area'  : 'Área bajo techo', value: '1,491 ft² / 139 m²' },
    { label: isEN ? 'A/C area'      : 'Área bajo aire',  value: '1,207 ft² / 112 m²' },
