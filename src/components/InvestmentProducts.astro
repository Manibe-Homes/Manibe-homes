---
import type { Translations } from '../i18n/translations';
interface Props { t: Translations; }
const { t } = Astro.props;
const p = t.products;
---

<section id="productos" class="py-24 bg-earth-50 relative overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-earth-200 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-16 reveal-fade">
      <span class="inline-block text-earth-500 text-sm font-semibold tracking-widest uppercase mb-4">
        {p.tag}
      </span>
      <h2 class="section-title text-earth-900 mb-6">
        {p.title1}<br />
        <span class="text-earth-600">{p.title2}</span>
      </h2>
      <p class="text-earth-500 text-lg max-w-2xl mx-auto font-body leading-relaxed">
        {p.intro}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {p.items.map((product, i) => (
        <div class={`reveal delay-${(i + 1) * 100} relative flex flex-col rounded-2xl overflow-hidden
                    border transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl
                    ${'featured' in product && product.featured
                      ? 'bg-earth-900 border-gold-400/50 shadow-xl shadow-earth-900/30 ring-2 ring-gold-400/30'
                      : 'bg-white border-earth-100 shadow-lg hover:border-earth-200'
                    }`}>

          {'featured' in product && product.featured && (
            <div class="absolute top-4 right-4">
              <span class="bg-gold-400 text-earth-900 text-xs font-bold px-3 py-1 rounded-full">
                {p.popular}
              </span>
            </div>
          )}

          <div class="h-1.5" style={'featured' in product && product.featured
            ? 'background: linear-gradient(to right, #dbc06a, #c4a95a)'
            : 'background: linear-gradient(to right, rgba(219,192,106,0.2), rgba(196,169,90,0.1))'}>
          </div>

          <div class="p-8 flex flex-col flex-1">
            <div class="flex items-center justify-between mb-6">
              <span class={`font-heading font-bold text-4xl ${'featured' in product && product.featured ? 'text-gold-400/30' : 'text-earth-100'}`}>
                {product.number}
              </span>
              <span class={`text-xs font-semibold px-3 py-1 rounded-full border
                ${'featured' in product && product.featured
                  ? 'text-earth-200 bg-earth-600/50 border-earth-500'
                  : 'text-gold-400 bg-gold-400/10 border-gold-400/30'
                }`}>
                {product.badge}
              </span>
            </div>

            <h3 class={`font-heading text-xl font-bold mb-3 ${'featured' in product && product.featured ? 'text-white' : 'text-earth-900'}`}>
              {product.name}
            </h3>

            <div class={`flex items-baseline gap-2 mb-4 pb-4 border-b ${'featured' in product && product.featured ? 'border-earth-700' : 'border-earth-100'}`}>
              <span class="font-heading text-4xl font-bold text-gold-400">{product.roi}</span>
              <span class={`text-sm font-body ${'featured' in product && product.featured ? 'text-earth-300' : 'text-earth-500'}`}>
                {product.roiPeriod}
              </span>
            </div>

            <div class={`flex items-center gap-2 text-sm mb-4 ${'featured' in product && product.featured ? 'text-earth-300' : 'text-earth-500'}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gold-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {p.termLabel}: <strong class={'featured' in product && product.featured ? 'text-white ml-1' : 'text-earth-700 ml-1'}>{product.term}</strong>
            </div>

            <p class={`text-sm leading-relaxed mb-6 ${'featured' in product && product.featured ? 'text-earth-300' : 'text-earth-600'}`}>
              {product.description}
            </p>

            <ul class="space-y-2 mb-8 flex-1">
              {product.benefits.map((benefit) => (
                <li class="flex items-start gap-2.5">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gold-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class={`text-xs leading-relaxed ${'featured' in product && product.featured ? 'text-earth-300' : 'text-earth-600'}`}>
                    {benefit}
                  </span>
                </li>
              ))}
            </ul>

            <p class="text-xs italic mb-6 text-earth-400">
              <span class="not-italic font-semibold">{product.profileLabel}:</span> {product.profile}
            </p>

            <a href="#contacto"
              class={`mt-auto text-center font-semibold text-sm px-6 py-3 rounded-xl transition-all duration-200
                ${'featured' in product && product.featured
                  ? 'bg-gold-400 hover:bg-gold-500 text-earth-900 shadow-lg shadow-gold-400/20'
                  : 'border-2 border-earth-200 hover:border-earth-400 text-earth-700 hover:text-earth-900'
                }`}>
              {p.ctaLabel}
            </a>
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-earth-500 text-sm mt-10 reveal">
      {p.disclaimer}
      <a href="#contacto" class="text-earth-700 font-semibold hover:text-earth-900 underline underline-offset-2">{p.disclaimerLink}</a>{p.disclaimerSuffix}
    </p>
  </div>
</section>
