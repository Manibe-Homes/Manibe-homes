---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
  lang: 'es' | 'en';
}
const { t, lang } = Astro.props;

const languages = [
  { code: 'es', label: 'Español', flagSrc: 'https://flagcdn.com/w40/es.png', flagAlt: 'España', href: '/' },
  { code: 'en', label: 'English', flagSrc: 'https://flagcdn.com/w40/us.png', flagAlt: 'United States', href: '/en/' },
];
const currentLang = languages.find(l => l.code === lang)!;
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  data-transparent="true"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">

      <!-- Logo -->
      <a href="#inicio" class="flex items-center flex-shrink-0">
        <img
          src="/logo-manibe-blanco.png"
          alt="Manibe LLC"
          class="h-12 w-auto object-contain"
        />
      </a>

      <!-- Desktop Nav Links -->
      <nav class="hidden lg:flex items-center gap-8">
        <a href="#inicio"    data-section="inicio"    class="nav-link">{t.nav.home}</a>
        <a href="#nosotros"  data-section="nosotros"  class="nav-link">{t.nav.about}</a>
        <a href="#modelos"   data-section="modelos"   class="nav-link">{t.nav.models}</a>
        <a href="#productos" data-section="productos" class="nav-link">{t.nav.invest}</a>
        <a href="#contacto"  data-section="contacto"  class="nav-link">{t.nav.contact}</a>
      </nav>

      <!-- CTA + Language switcher + Mobile Menu Button -->
      <div class="flex items-center gap-3">

        <!-- Language switcher dropdown -->
        <div class="hidden sm:block relative" id="lang-dropdown-wrapper">
          <button
            id="lang-dropdown-btn"
            aria-haspopup="true"
            aria-expanded="false"
            class="inline-flex items-center gap-1.5 px-2.5 h-9 rounded-full
                   border border-white/30 text-white/80 hover:border-gold-400 hover:text-gold-400
                   font-body font-semibold text-xs transition-all duration-200"
          >
            <img src={currentLang.flagSrc} alt={currentLang.flagAlt} class="w-5 h-auto rounded-sm" />
            <span>{currentLang.code.toUpperCase()}</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform duration-200" id="lang-chevron"
                 fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Dropdown panel -->
          <div
            id="lang-dropdown-panel"
            class="hidden absolute right-0 mt-2 w-36 rounded-xl border border-earth-700
                   bg-earth-900 shadow-xl shadow-black/40 overflow-hidden z-50"
          >
            {languages.map(l => (
              <a
                href={l.href}
                class={`flex items-center gap-2.5 px-3 py-2.5 text-sm font-body font-medium
                        transition-colors duration-150
                        ${l.code === lang
                          ? 'text-gold-400 bg-earth-800 cursor-default pointer-events-none'
                          : 'text-white/80 hover:bg-earth-800 hover:text-white'}`}
              >
                <img src={l.flagSrc} alt={l.flagAlt} class="w-5 h-auto rounded-sm flex-shrink-0" />
                <span>{l.label}</span>
                {l.code === lang && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 ml-auto text-gold-400" fill="none"
                       viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                )}
              </a>
            ))}
          </div>
        </div>

        <a
          href="/portal"
          class="hidden sm:inline-flex items-center gap-2 bg-gold-400 hover:bg-gold-500 active:bg-gold-600
                 text-earth-900 font-body font-semibold text-sm px-5 py-2.5 rounded-full
                 transition-all duration-200 shadow-md hover:shadow-lg"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          {t.nav.portal}
        </a>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-lg text-white hover:bg-white/10 transition-colors"
          aria-label="Open menu"
        >
          <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-earth-900 border-t border-earth-700">
    <div class="px-4 py-4 space-y-1">
      <a href="#inicio"    data-section="inicio"    class="mobile-link">{t.nav.home}</a>
      <a href="#nosotros"  data-section="nosotros"  class="mobile-link">{t.nav.about}</a>
      <a href="#modelos"   data-section="modelos"   class="mobile-link">{t.nav.models}</a>
      <a href="#productos" data-section="productos" class="mobile-link">{t.nav.invest}</a>
      <a href="#contacto"  data-section="contacto"  class="mobile-link">{t.nav.contact}</a>
      <!-- Language options in mobile menu -->
      <div class="border-t border-earth-700 pt-2 mt-1">
        {languages.map(l => (
          <a
            href={l.href}
            class={`flex items-center gap-2.5 px-3 py-2.5 rounded-lg font-body font-medium text-sm
                    transition-colors
                    ${l.code === lang
                      ? 'text-gold-400 bg-earth-800 pointer-events-none'
                      : 'text-white/80 hover:text-white hover:bg-white/5'}`}
          >
            <span class="text-base leading-none">{l.flag}</span>
            <span>{l.label}</span>
            {l.code === lang && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 ml-auto text-gold-400" fill="none"
                   viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
            )}
          </a>
        ))}
      </div>
      <div class="pt-3 pb-1">
        <a
          href="/portal"
          class="block w-full text-center bg-gold-400 hover:bg-gold-500 text-earth-900
                 font-semibold px-5 py-3 rounded-full transition-colors"
        >
          {t.nav.portal}
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  #navbar[data-transparent="true"] {
    background: transparent;
  }
  #navbar[data-transparent="false"] {
    background: #0c1524;
    box-shadow: 0 1px 20px rgba(0, 0, 0, 0.4);
  }
  .nav-link {
    @apply text-white/90 hover:text-gold-400 font-body font-medium text-sm
           transition-colors duration-200 tracking-wide relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 2px;
    background: #dbc06a;
    border-radius: 1px;
    transform: scaleX(0);
    transition: transform 0.25s ease;
    transform-origin: center;
  }
  .nav-link.active {
    color: #dbc06a;
  }
  .nav-link.active::after {
    transform: scaleX(1);
  }
  .mobile-link {
    @apply block text-white/90 hover:text-gold-400 font-body font-medium
           px-3 py-2.5 rounded-lg hover:bg-white/5 transition-colors;
  }
  .mobile-link.active {
    @apply text-gold-400 bg-earth-800;
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  function updateNavbar() {
    const isTop = window.scrollY < 80;
    navbar?.setAttribute('data-transparent', isTop ? 'true' : 'false');
  }
  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();

  mobileMenuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });

  // Language dropdown
  const langBtn = document.getElementById('lang-dropdown-btn');
  const langPanel = document.getElementById('lang-dropdown-panel');
  const langChevron = document.getElementById('lang-chevron');

  function closeLangDropdown() {
    langPanel?.classList.add('hidden');
    langBtn?.setAttribute('aria-expanded', 'false');
    langChevron?.classList.remove('rotate-180');
  }

  langBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = !langPanel?.classList.contains('hidden');
    if (isOpen) {
      closeLangDropdown();
    } else {
      langPanel?.classList.remove('hidden');
      langBtn.setAttribute('aria-expanded', 'true');
      langChevron?.classList.add('rotate-180');
    }
  });

  document.addEventListener('click', closeLangDropdown);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLangDropdown();
  });

  // ── Active section indicator ──────────────────────────────────────────
  // Must match DOM order (top → bottom) for the "last above threshold" logic to work
  const sectionIds = ['inicio', 'productos', 'modelos', 'nosotros', 'contacto'];
  const allNavLinks = document.querySelectorAll<HTMLElement>('[data-section]');

  function setActiveSection(id: string) {
    allNavLinks.forEach((link) => {
      const isActive = link.dataset.section === id;
      link.classList.toggle('active', isActive);
    });
  }

  function detectActiveSection() {
    // Find the section whose top edge is closest to (but above) 40% of the viewport
    const threshold = window.innerHeight * 0.4;
    let activeId = sectionIds[0];

    for (const id of sectionIds) {
      const el = document.getElementById(id);
      if (!el) continue;
      const top = el.getBoundingClientRect().top;
      if (top <= threshold) activeId = id;
    }
    setActiveSection(activeId);
  }

  window.addEventListener('scroll', detectActiveSection, { passive: true });
  detectActiveSection();
</script>
