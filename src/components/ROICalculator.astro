---
import type { Translations } from '../i18n/translations';
interface Props { t: Translations; }
const { t } = Astro.props;
const c = t.calculator;
---

<section id="calculadora" class="py-24 bg-earth-900 relative overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-400/30 to-transparent"></div>
  <div class="absolute -top-32 -right-32 w-96 h-96 bg-gold-400/5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-earth-700/30 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-12 reveal">
      <span class="inline-block text-gold-400 text-sm font-semibold tracking-widest uppercase mb-4">
        {c.tag}
      </span>
      <h2 class="section-title text-white mb-4">
        {c.title1} <span class="text-gold-400">{c.title2}</span>
      </h2>
      <p class="text-earth-300 text-lg font-body max-w-xl mx-auto leading-relaxed">
        {c.intro}
      </p>
    </div>

    <!-- Calculator card -->
    <div class="reveal bg-earth-800/60 backdrop-blur-sm border border-earth-700 rounded-3xl p-6 sm:p-10 shadow-2xl">

      <!-- Amount input -->
      <div class="mb-8">
        <label for="calc-amount" class="block text-earth-300 text-sm font-semibold mb-3 tracking-wide uppercase">
          {c.amountLabel}
        </label>
        <div class="relative">
          <span class="absolute left-5 top-1/2 -translate-y-1/2 text-gold-400 font-bold text-xl">$</span>
          <input
            id="calc-amount"
            type="text"
            inputmode="numeric"
            placeholder={c.amountPlaceholder}
            value="50,000"
            class="w-full bg-earth-700/50 border-2 border-earth-600 focus:border-gold-400
                   text-white placeholder-earth-500 rounded-2xl pl-12 pr-6 py-5
                   font-heading text-2xl font-bold focus:outline-none focus:ring-0
                   transition-colors duration-200"
          />
        </div>
        <!-- Slider -->
        <div class="mt-4 px-1">
          <input
            id="calc-slider"
            type="range"
            min="10000"
            max="500000"
            step="5000"
            value="50000"
            class="calc-slider w-full h-2 rounded-full appearance-none cursor-pointer"
          />
          <div class="flex justify-between text-earth-500 text-xs mt-2 font-body">
            <span>$10,000</span>
            <span>$500,000</span>
          </div>
        </div>
      </div>

      <!-- Product selector -->
      <div class="mb-8">
        <p class="text-earth-300 text-sm font-semibold mb-3 tracking-wide uppercase">Producto</p>
        <div class="grid sm:grid-cols-2 gap-3">
          <button
            id="calc-p1"
            data-product="1"
            class="calc-product-btn active text-left p-4 rounded-2xl border-2 transition-all duration-200"
          >
            <span class="block font-heading font-bold text-base mb-1">{c.product1}</span>
            <span class="text-xs font-body">{c.product1Detail}</span>
          </button>
          <button
            id="calc-p2"
            data-product="2"
            class="calc-product-btn text-left p-4 rounded-2xl border-2 transition-all duration-200"
          >
            <span class="block font-heading font-bold text-base mb-1">{c.product2}</span>
            <span class="text-xs font-body">{c.product2Detail}</span>
          </button>
        </div>
      </div>

      <!-- Results -->
      <div id="calc-results" class="grid sm:grid-cols-3 gap-4 mb-8">

        <!-- Capital -->
        <div class="bg-earth-700/50 border border-earth-600 rounded-2xl p-5 text-center">
          <p class="text-earth-400 text-xs font-semibold uppercase tracking-wider mb-2">{c.initialLabel}</p>
          <p id="calc-capital" class="font-heading text-2xl font-bold text-white">$50,000</p>
          <p class="text-earth-500 text-xs mt-1">&nbsp;</p>
        </div>

        <!-- Profit -->
        <div class="bg-earth-700/50 border border-gold-400/30 rounded-2xl p-5 text-center relative overflow-hidden">
          <div class="absolute inset-0 bg-gold-400/5 pointer-events-none"></div>
          <p class="text-earth-400 text-xs font-semibold uppercase tracking-wider mb-2">{c.profitLabel}</p>
          <p id="calc-profit" class="font-heading text-2xl font-bold text-gold-400">$3,000 – $5,000</p>
          <p id="calc-profit-sub" class="text-earth-400 text-xs mt-1">6% – 10% total</p>
        </div>

        <!-- Total -->
        <div class="bg-earth-700/50 border border-earth-600 rounded-2xl p-5 text-center">
          <p class="text-earth-400 text-xs font-semibold uppercase tracking-wider mb-2">{c.totalLabel}</p>
          <p id="calc-total" class="font-heading text-2xl font-bold text-white">$53,000 – $55,000</p>
          <p id="calc-term" class="text-earth-500 text-xs mt-1">{c.months6}</p>
        </div>

      </div>

      <!-- CTA -->
      <a
        href="#contacto"
        class="flex items-center justify-center gap-2 w-full bg-gold-400 hover:bg-gold-500
               active:bg-gold-600 text-earth-900 font-semibold text-sm px-6 py-4 rounded-2xl
               transition-all duration-200 shadow-lg hover:shadow-gold-400/25"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
        </svg>
        {c.cta}
      </a>

      <p class="text-earth-500 text-xs text-center mt-5 leading-relaxed font-body">
        {c.disclaimer}
      </p>
    </div>
  </div>
</section>

<style>
  .calc-slider {
    background: linear-gradient(to right, #dbc06a 0%, #dbc06a var(--pct, 8.16%), #2c3a5c var(--pct, 8.16%), #2c3a5c 100%);
  }
  .calc-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #dbc06a;
    cursor: pointer;
    border: 3px solid #0c1524;
    box-shadow: 0 0 0 2px #dbc06a40;
  }
  .calc-slider::-moz-range-thumb {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #dbc06a;
    cursor: pointer;
    border: 3px solid #0c1524;
  }

  .calc-product-btn {
    border-color: #2c3a5c;
    background: rgba(44, 58, 92, 0.3);
    color: #8894b0;
  }
  .calc-product-btn span:first-child { color: #8894b0; }
  .calc-product-btn.active {
    border-color: #dbc06a;
    background: rgba(219, 192, 106, 0.08);
    color: #ffffff;
  }
  .calc-product-btn.active span:first-child { color: #ffffff; }
  .calc-product-btn.active span:last-child { color: #dbc06a; }
  .calc-product-btn:hover:not(.active) {
    border-color: #3d4f72;
    background: rgba(61, 79, 114, 0.3);
  }
</style>

<script define:vars={{ months6: c.months6, months12: c.months12, minLabel: c.minLabel, maxLabel: c.maxLabel }}>
  const amountInput = document.getElementById('calc-amount');
  const slider      = document.getElementById('calc-slider');
  const p1btn       = document.getElementById('calc-p1');
  const p2btn       = document.getElementById('calc-p2');
  const elCapital   = document.getElementById('calc-capital');
  const elProfit    = document.getElementById('calc-profit');
  const elProfitSub = document.getElementById('calc-profit-sub');
  const elTotal     = document.getElementById('calc-total');
  const elTerm      = document.getElementById('calc-term');

  let activeProduct = 1;
  let rawAmount = 50000;

  function fmt(n) {
    return '$' + Math.round(n).toLocaleString('en-US');
  }

  function fmtRange(a, b) {
    return fmt(a) + ' – ' + fmt(b);
  }

  function updateSliderTrack() {
    const min = 10000, max = 500000;
    const pct = ((rawAmount - min) / (max - min)) * 100;
    slider.style.setProperty('--pct', pct.toFixed(2) + '%');
  }

  function calculate() {
    elCapital.textContent = fmt(rawAmount);

    if (activeProduct === 1) {
      // 12%–20% directly on capital over ~6 months
      const minProfit = rawAmount * 0.12;
      const maxProfit = rawAmount * 0.20;
      elProfit.textContent    = fmtRange(minProfit, maxProfit);
      elProfitSub.textContent = `12% ${minLabel} · 20% ${maxLabel}`;
      elTotal.textContent     = fmtRange(rawAmount + minProfit, rawAmount + maxProfit);
      elTerm.textContent      = months6;
    } else {
      // 14% annual, 12 months → 14% total
      const profit = rawAmount * 0.14;
      elProfit.textContent    = fmt(profit);
      elProfitSub.textContent = '14% anual fijo';
      elTotal.textContent     = fmt(rawAmount + profit);
      elTerm.textContent      = months12;
    }
  }

  // Sync input ↔ slider
  amountInput?.addEventListener('input', () => {
    const digits = amountInput.value.replace(/\D/g, '');
    rawAmount = Math.min(Math.max(parseInt(digits) || 0, 0), 500000);
    amountInput.value = rawAmount.toLocaleString('en-US');
    slider.value = String(rawAmount);
    updateSliderTrack();
    calculate();
  });

  slider?.addEventListener('input', () => {
    rawAmount = parseInt(slider.value);
    amountInput.value = rawAmount.toLocaleString('en-US');
    updateSliderTrack();
    calculate();
  });

  // Product tabs
  [p1btn, p2btn].forEach(btn => {
    btn?.addEventListener('click', () => {
      activeProduct = parseInt(btn.dataset.product);
      p1btn?.classList.toggle('active', activeProduct === 1);
      p2btn?.classList.toggle('active', activeProduct === 2);
      calculate();
    });
  });

  // Init
  updateSliderTrack();
  calculate();
</script>
